# Environment Variables

# Node Environment
NODE_ENV=development

# Feature Flags (optional)
# NEXT_PUBLIC_ENABLE_DEBUG_UI=false
# NEXT_PUBLIC_ENABLE_ADVANCED_FEATURES=true

# Analytics (optional)
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# MediaPipe CDN (optional - defaults to jsdelivr)
# NEXT_PUBLIC_MEDIAPIPE_CDN=https://cdn.jsdelivr.net/npm/@mediapipe/face_mesh

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Admin Authentication
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me
ADMIN_JWT_SECRET=change-me-random-32-chars